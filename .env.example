# Google Drive OAuth
GOOGLE_CLIENT_SECRET_PATH=/path/to/client_secret.json
GOOGLE_TOKEN_PATH=/path/to/.google_token.pickle

# Google Drive — shared folder ID
# Open the shared Interview DB folder in browser → copy the ID from the URL
# e.g. https://drive.google.com/drive/folders/FOLDER_ID_HERE
INTERVIEW_ROOT_FOLDER_ID=

# Google Drive folder / sheet names (keep as-is unless renamed)
INTERVIEW_DB_FOLDER_NAME=Interview DB
INTERVIEW_SHEET_NAME=Interview Question Bank

# Default season for new entries
INTERVIEW_SEASON=2025-2026

# Notion — fill in your own DB ID and data source ID
NOTION_DB_ID=
NOTION_DATA_SOURCE_ID=
