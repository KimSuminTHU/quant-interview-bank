# Google Drive OAuth
GOOGLE_CLIENT_SECRET_PATH=/path/to/client_secret.json
GOOGLE_TOKEN_PATH=/path/to/.google_token.pickle

# Google Drive — Shared Drive ID (leave empty to use personal Drive root)
# Find it: open Shared Drive in browser → copy ID from URL
INTERVIEW_SHARED_DRIVE_ID=

# Google Drive folder / sheet names (keep as-is unless you rename them)
INTERVIEW_DB_FOLDER_NAME=Interview DB
INTERVIEW_SHEET_NAME=Interview Question Bank

# Default season for new entries
INTERVIEW_SEASON=2025-2026

# Notion — get from your DB URL and Notion MCP fetch
NOTION_DB_ID=
NOTION_DATA_SOURCE_ID=
